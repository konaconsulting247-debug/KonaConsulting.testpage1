<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --primary: #A0826D;
    --primary-dark: #7A5F4F;
    --secondary: #F8A996;
    --secondary-light: #F5C4A8;
    --light-tan: #F0EAE0;
    --light-tan-dark: #E8DFD3;
    --text-dark: #3D2817;
    --text-mid: #5C4B3D;
    --text-muted: #8B7A6B;
    --white: #FFFFFF;
    --serif: 'Cormorant Garamond', Georgia, serif;
    --sans: 'DM Sans', system-ui, sans-serif;
  }

  html { scroll-behavior: smooth; }
  body { font-family: var(--sans); color: var(--text-dark); background: var(--white); overflow-x: hidden; }

  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 1.25rem 4rem;
    background: rgba(160, 130, 109, 0.96);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(248, 169, 150, 0.2);
