  .nav-logo { display: flex; align-items: center; gap: 0.75rem; text-decoration: none; }
  .logo-mark {
    width: 36px; height: 36px; border: 1.5px solid var(--secondary);
    border-radius: 50%; display: flex; align-items: center; justify-content: center;
    font-size: 20px;
  }
  .logo-text { font-family: var(--serif); font-size: 18px; font-weight: 500; color: var(--white); letter-spacing: 0.12em; text-transform: uppercase; }
  .nav-links { display: flex; align-items: center; gap: 2.5rem; list-style: none; }
  .nav-links a { font-size: 13px; font-weight: 400; letter-spacing: 0.08em; text-transform: uppercase; text-decoration: none; color: rgba(247,244,238,0.75); transition: color 0.2s; }
  .nav-links a:hover { color: var(--secondary-light); }
  .nav-cta { font-size: 12px; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; text-decoration: none; color: var(--secondary) !important; border: 1px solid var(--secondary); padding: 0.5rem 1.25rem; transition: all 0.2s !important; }
  .nav-cta:hover { background: var(--secondary) !important; color: var(--primary) !important; }

  .hero { min-height: 100vh; background: var(--primary); display: flex; align-items: center; position: relative; overflow: hidden; }
  .hero-grid { position: absolute; inset: 0; background-image: linear-gradient(rgba(248,169,150,0.06) 1px, transparent 1px), linear-gradient(90deg, rgba(248,169,150,0.06) 1px, transparent 1px); background-size: 60px 60px; }
  .hero-accent { position: absolute; right: -120px; top: 50%; transform: translateY(-50%); width: 620px; height: 620px; border-radius: 50%; border: 1px solid rgba(248,169,150,0.15); }
  .hero-accent::before { content: ''; position: absolute; inset: 40px; border-radius: 50%; border: 1px solid rgba(248,169,150,0.1); }
  .hero-accent::after { content: ''; position: absolute; inset: 80px; border-radius: 50%; border: 1px solid rgba(248,169,150,0.07); }
  .hero-content { position: relative; z-index: 2; max-width: 1200px; margin: 0 auto; padding: 0 4rem; padding-top: 80px; }
  .hero-eyebrow { display: flex; align-items: center; gap: 1rem; margin-bottom: 2rem; }
  .hero-eyebrow-line { width: 48px; height: 1px; background: var(--secondary); }
  .hero-eyebrow span { font-size: 12px; font-weight: 400; letter-spacing: 0.18em; text-transform: uppercase; color: var(--secondary-light); }
  .hero h1 { font-family: var(--serif); font-size: clamp(52px, 7vw, 88px); font-weight: 300; line-height: 1.08; color: var(--white); margin-bottom: 2rem; max-width: 700px; }
  .hero h1 em { font-style: italic; color: var(--secondary-light); }
  .hero-sub { font-size: 16px; font-weight: 300; line-height: 1.8; color: rgba(247,244,238,0.65); max-width: 480px; margin-bottom: 3rem; }
  .hero-actions { display: flex; align-items: center; gap: 1.5rem; }
  .btn-primary { display: inline-block; text-decoration: none; font-size: 13px; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; background: var(--secondary); color: var(--primary); padding: 1rem 2.5rem; transition: background 0.2s, transform 0.15s; }
  .btn-primary:hover { background: var(--secondary-light); transform: translateY(-1px); }
  .btn-ghost { display: inline-flex; align-items: center; gap: 0.5rem; text-decoration: none; font-size: 13px; font-weight: 400; letter-spacing: 0.08em; color: rgba(247,244,238,0.75); transition: color 0.2s; }
  .btn-ghost:hover { color: var(--secondary-light); }

  .stats-bar { background: var(--light-tan); border-top: 1px solid var(--light-tan-dark); border-bottom: 1px solid var(--light-tan-dark); }
  .stats-inner { max-width: 1200px; margin: 0 auto; padding: 0 4rem; display: grid; grid-template-columns: repeat(4, 1fr); }
  .stat-item { padding: 2.5rem 2rem; border-right: 1px solid var(--light-tan-dark); text-align: center; }
  .stat-item:last-child { border-right: none; }
  .stat-num { font-family: var(--serif); font-size: 48px; font-weight: 300; color: var(--primary); line-height: 1; margin-bottom: 0.5rem; }
  .stat-num span { color: var(--secondary); }
  .stat-label { font-size: 12px; font-weight: 400; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-muted); }

  section { padding: 7rem 0; }
  .container { max-width: 1200px; margin: 0 auto; padding: 0 4rem; }
  .section-eyebrow { display: flex; align-items: center; gap: 1rem; margin-bottom: 1.25rem; }
  .section-eyebrow-line { width: 32px; height: 1px; background: var(--secondary); }
  .section-eyebrow span { font-size: 11px; font-weight: 400; letter-spacing: 0.18em; text-transform: uppercase; color: var(--secondary); }
  .section-title { font-family: var(--serif); font-size: clamp(36px, 5vw, 56px); font-weight: 300; line-height: 1.15; color: var(--text-dark); }
  .section-title em { font-style: italic; color: var(--secondary); }
  .section-body { font-size: 16px; font-weight: 300; line-height: 1.85; color: var(--text-mid); max-width: 520px; }

  .about { background: var(--white); }
  .about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center; }
  .about-image-block { position: relative; }
  .about-img-frame { width: 100%; aspect-ratio: 4/5; background: var(--primary-dark); position: relative; overflow: hidden; }
  .about-img-inner { position: absolute; inset: 0; background: linear-gradient(135deg, var(--primary) 0%, #6B5243 100%); display: flex; align-items: center; justify-content: center; }
  .about-img-pattern { position: absolute; inset: 0; opacity: 0.15; background-image: linear-gradient(rgba(248,169,150,0.4) 1px, transparent 1px), linear-gradient(90deg, rgba(248,169,150,0.4) 1px, transparent 1px); background-size: 30px 30px; }
  .about-img-text { position: relative; z-index: 2; text-align: center; font-size: 72px; }
  .about-img-badge { position: absolute; bottom: -20px; right: -20px; background: var(--secondary); padding: 1.5rem; text-align: center; min-width: 130px; }
  .about-img-badge .num { font-family: var(--serif); font-size: 36px; font-weight: 300; color: var(--primary); display: block; line-height: 1; }
  .about-img-badge .lbl { font-size: 10px; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: var(--primary-dark); }
  .about-values { display: flex; flex-direction: column; gap: 1rem; margin-top: 2rem; }
  .about-value { display: flex; align-items: flex-start; gap: 1rem; padding: 1rem 0; border-bottom: 1px solid var(--light-tan-dark); }
  .about-value:first-child { border-top: 1px solid var(--light-tan-dark); }
  .value-num { font-family: var(--serif); font-size: 14px; font-weight: 400; color: var(--secondary); min-width: 24px; padding-top: 2px; }
  .value-text h4 { font-size: 14px; font-weight: 500; letter-spacing: 0.04em; color: var(--text-dark); margin-bottom: 0.25rem; }
  .value-text p { font-size: 14px; font-weight: 300; color: var(--text-muted); line-height: 1.6; }

  .services { background: var(--primary); }
  .services .section-title { color: var(--white); }
  .services .section-body { color: rgba(245,245,240,0.6); }
  .services-header { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: end; margin-bottom: 4rem; }
  .services-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: rgba(248,169,150,0.15); border: 1px solid rgba(248,169,150,0.15); }
  .service-card { background: var(--primary); padding: 2.5rem; position: relative; overflow: hidden; transition: background 0.3s; }
  .service-card::before { content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 2px; background: var(--secondary); transform: scaleX(0); transform-origin: left; transition: transform 0.3s; }
  .service-card:hover { background: var(--primary-dark); }
  .service-card:hover::before { transform: scaleX(1); }
  .service-icon { width: 40px; height: 40px; border: 1px solid rgba(248,169,150,0.4); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 1.5rem; }
  .service-icon svg { width: 18px; height: 18px; stroke: var(--secondary); fill: none; stroke-width: 1.5; }
  .service-card h3 { font-family: var(--serif); font-size: 22px; font-weight: 400; color: var(--white); margin-bottom: 1rem; line-height: 1.3; }
  .service-card p { font-size: 14px; font-weight: 300; line-height: 1.8; color: rgba(247,244,238,0.55); }

  .process { background: var(--light-tan); }
  .process-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center; }
  .process-steps { display: flex; flex-direction: column; gap: 0; }
  .process-step { display: flex; gap: 1.5rem; padding: 2rem 0; border-bottom: 1px solid var(--light-tan-dark); }
  .process-step:first-child { border-top: 1px solid var(--light-tan-dark); }
  .step-num { font-family: var(--serif); font-size: 40px; font-weight: 300; color: rgba(61,40,23,0.12); line-height: 1; min-width: 48px; }
  .step-content h4 { font-size: 15px; font-weight: 500; color: var(--text-dark); margin-bottom: 0.4rem; }
  .step-content p { font-size: 14px; font-weight: 300; color: var(--text-muted); line-height: 1.7; }

  .testimonials { background: var(--white); }
  .testimonials-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }
  .testimonial-card { border: 1px solid var(--light-tan-dark); padding: 2rem; }
  .quote-mark { font-family: var(--serif); font-size: 80px; font-weight: 300; color: var(--secondary); line-height: 0.6; margin-bottom: 1rem; display: block; opacity: 0.4; }
  .testimonial-text { font-family: var(--serif); font-size: 17px; font-weight: 400; line-height: 1.65; color: var(--text-dark); font-style: italic; margin-bottom: 1.5rem; }
  .testimonial-author { display: flex; align-items: center; gap: 0.75rem; }
  .author-avatar { width: 40px; height: 40px; border-radius: 50%; background: var(--primary-dark); display: flex; align-items: center; justify-content: center; font-family: var(--serif); font-size: 14px; color: var(--secondary-light); font-weight: 500; }
  .author-name { font-size: 14px; font-weight: 500; color: var(--text-dark); }
  .author-title { font-size: 12px; color: var(--text-muted); margin-top: 1px; }

  .contact-form { background: var(--light-tan); }
  .contact-form-inner { max-width: 600px; margin: 0 auto; }
  .form-group { margin-bottom: 1.5rem; }
  .form-group label { display: block; font-size: 14px; font-weight: 500; margin-bottom: 0.5rem; color: var(--text-dark); letter-spacing: 0.04em; }
  .form-group input, .form-group textarea { width: 100%; padding: 0.75rem 1rem; font-size: 14px; border: 1px solid var(--light-tan-dark); border-radius: 4px; font-family: var(--sans); color: var(--text-dark); transition: border 0.2s, background 0.2s; }
  .form-group input:focus, .form-group textarea:focus { outline: none; border-color: var(--secondary); background: var(--white); }
  .form-group textarea { resize: vertical; min-height: 120px; }
  .form-submit { width: 100%; padding: 0.75rem 1rem; font-size: 13px; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; background: var(--secondary); color: var(--primary); border: none; border-radius: 4px; cursor: pointer; transition: background 0.2s, transform 0.15s; }
  .form-submit:hover { background: var(--secondary-light); transform: translateY(-1px); }

  .cta-section { background: var(--primary); padding: 7rem 0; position: relative; overflow: hidden; }
  .cta-bg-text { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); font-family: var(--serif); font-size: 240px; font-weight: 300; color: rgba(248,169,150,0.04); white-space: nowrap; pointer-events: none; }
  .cta-inner { position: relative; z-index: 2; text-align: center; max-width: 700px; margin: 0 auto; padding: 0 4rem; }
  .cta-inner .section-eyebrow { justify-content: center; }
  .cta-inner h2 { font-family: var(--serif); font-size: clamp(40px, 6vw, 64px); font-weight: 300; line-height: 1.15; color: var(--white); margin-bottom: 1.5rem; }
  .cta-inner h2 em { font-style: italic; color: var(--secondary-light); }
  .cta-inner p { font-size: 16px; font-weight: 300; color: rgba(247,244,238,0.6); margin-bottom: 3rem; line-height: 1.8; }
  .cta-actions { display: flex; align-items: center; justify-content: center; gap: 1.5rem; }

  footer { background: #4A3A2F; padding: 4rem 0 2rem; border-top: 1px solid rgba(248,169,150,0.15); }
  .footer-inner { max-width: 1200px; margin: 0 auto; padding: 0 4rem; }
  .footer-top { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 3rem; padding-bottom: 3rem; border-bottom: 1px solid rgba(255,255,255,0.06); margin-bottom: 2rem; }
  .footer-brand p { font-size: 14px; font-weight: 300; color: rgba(247,244,238,0.45); line-height: 1.8; margin-top: 1rem; }
  .footer-col h5 { font-size: 11px; font-weight: 500; letter-spacing: 0.14em; text-transform: uppercase; color: var(--secondary); margin-bottom: 1.25rem; }
  .footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 0.7rem; }
  .footer-col ul li a { font-size: 14px; font-weight: 300; color: rgba(247,244,238,0.5); text-decoration: none; transition: color 0.2s; }
  .footer-col ul li a:hover { color: var(--secondary-light); }
  .footer-bottom { display: flex; align-items: center; justify-content: space-between; }
  .footer-copy { font-size: 12px; color: rgba(247,244,238,0.3); }
  .footer-tagline { font-family: var(--serif); font-size: 13px; font-style: italic; color: rgba(248,169,150,0.5); }

  @keyframes fadeUp { from { opacity: 0; transform: translateY(24px); } to { opacity: 1; transform: translateY(0); } }
  .hero-content > * { animation: fadeUp 0.8s ease both; }

  @media (max-width: 900px) {
    nav { padding: 1rem 1.5rem; }
    .nav-links { display: none; }
    .container { padding: 0 1.5rem; }
    .about-grid, .process-grid, .services-header { grid-template-columns: 1fr; gap: 2rem; }
    .services-grid { grid-template-columns: 1fr; }
    .testimonials-grid { grid-template-columns: 1fr; }
    .stats-inner { grid-template-columns: 1fr 1fr; }
    section { padding: 4rem 0; }
  }
</style>
</head>
